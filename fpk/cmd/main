#!/bin/bash

PROJECT_DIR="$(dirname "$0")/.."
COMPOSE_FILE="${PROJECT_DIR}/app/docker/docker-compose.yaml"

case $1 in
  start)
    docker compose -f "${COMPOSE_FILE}" up -d || exit 1
    ;;
  stop)
    docker compose -f "${COMPOSE_FILE}" down 2>/dev/null || true
    exit 0
    ;;
  status)
    docker compose -f "${COMPOSE_FILE}" ps --status running 2>/dev/null | grep -q handbrake-webui || exit 3
    exit 0
    ;;
  *)
    exit 1
    ;;
esac