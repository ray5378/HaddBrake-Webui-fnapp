#!/bin/bash

find_compose_file() {
  for c in "${TRIM_APPDEST}/docker/docker-compose.yaml" \
           "${TRIM_APPDEST}/target/docker/docker-compose.yaml"; do
    if [ -f "$c" ]; then
      echo "$c"
      return 0
    fi
  done
  return 1
}

inject_drive_volume() {
  local compose_file="$1"
  local path="$2"
  [ ! -f "$compose_file" ] && return 1

  if [ -n "$path" ]; then
    mkdir -p "${TRIM_PKGVAR}" 2>/dev/null || true
    echo "$path" > "${TRIM_PKGVAR}/drive_path" 2>/dev/null || true
  fi

  sed -i '\|^      - .*:/drive|d' "$compose_file" 2>/dev/null || true

  [ -z "$path" ] && return 0

  sed -i "/^    volumes:/a\\      - ${path}:/drive" "$compose_file"
}

COMPOSE_FILE=$(find_compose_file)
if [ -z "$COMPOSE_FILE" ]; then
  echo "docker-compose.yaml not found, volumes will not be injected" >&2
  exit 0
fi

local_path=""
if [ -f "${TRIM_PKGVAR}/drive_path" ]; then
  local_path=$(cat "${TRIM_PKGVAR}/drive_path")
fi
if [ -z "$local_path" ] && [ -n "${TRIM_DATA_SHARE_PATHS}" ]; then
  local_path="${TRIM_DATA_SHARE_PATHS%%:*}"
fi

inject_drive_volume "$COMPOSE_FILE" "$local_path"

# Recreate container if a path is configured
if [ -n "$local_path" ] && command -v docker &>/dev/null; then
  CF=$(readlink -f "$COMPOSE_FILE")
  docker stop handbrake-webui 2>/dev/null || true
  docker rm handbrake-webui 2>/dev/null || true
  docker compose -f "$CF" up -d
fi

exit 0
